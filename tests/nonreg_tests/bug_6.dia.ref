tlbxs = atomsGetInstalled();
if grep(tlbxs, 'csv_readwrite') <> [] then
  atomsLoad("csv_readwrite");
else
  root_path = getenv('CSV_READWRITE_PATH', '');
  if root_path <> '' then 
    exec(root_path + 'loader.sce'); 
Start CSV read/write files.
	Load macros
	Load gateways
	Load help
	Load demos
  end 
end
// =============================================================================
M = rand(4,3);
csv_write(M, TMPDIR + '/csvlist.dat');
r = csv_read(TMPDIR + '/csvlist.dat',csv_default('separator'), csv_default('decimal'), 'double');
if abs(M-r) > %eps then bugmes();quit;end
// =============================================================================
