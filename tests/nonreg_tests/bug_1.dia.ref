tlbxs = atomsGetInstalled();
if grep(tlbxs, 'csv_readwrite') <> [] then
  atomsLoad("csv_readwrite");
else
  root_path = getenv('CSV_READWRITE_PATH', '');
  if root_path <> '' then 
    exec(root_path + 'loader.sce'); 
Start CSV read/write files.
	Load macros
	Load gateways
	Load help
	Load demos
  end 
end
// =============================================================================
r = csv_read(csv_getToolboxPath() + "tests/nonreg_tests/bug_1.csv", ",");
if size(r, "c") <> 2 then bugmes();quit;end
if size(r, "r") <> 7534 then bugmes();quit;end
if r(1,1) <> "Time" then bugmes();quit;end
if r(1,2) <> "ecart" then bugmes();quit;end
if r(7534,1) <> "0.05" then bugmes();quit;end
if r(7534,2) <> "-0.000237359" then bugmes();quit;end
